{"componentChunkName":"component---node-modules-carrotsearch-gatsby-theme-apidocs-templates-documentation-page-js","path":"/v4.8.x/","result":{"data":{"site":{"siteMetadata":{"title":"Carrot2 docs","description":"User and developer manual for the Carrot2 text clustering engine.","lang":"en","indexAlias":"/hello-carrot2/"}},"html":{"frontmatter":{"id":"v4.8.x","title":"Carrot2 4.8.x"},"html":"<article>\n  <h1>Carrot<sup>2</sup> 4.8.x</h1>\n\n  <p id=\"572ffd0c\">\n    Release history for Carrot2 4.8.0 and bugfix releases.\n  </p>\n\n  <section id=\"v4.8.5\">\n    <h2>\n        <a class=\"anchor\" href=\"#v4.8.5\" aria-hidden=\"true\"><svg aria-hidden=\"true\" height=\"16\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Version 4.8.5\n      </h2>\n\n    <time datetime=\"2026-03-06\"></time>\n\n    <p id=\"v4.8.5:37bc04be\">\n      The 4.8.5 release upgrades Jetty to 12.x, Jackson to 2.21.1,\n      Lucene to 10.4.0, and other dependency and build infrastructure\n      updates. A new option to start the DCS with just the service has been added.\n    </p>\n\n    <dl>\n      <dt>Jetty version strings omitted</dt>\n      <dd>\n        <p id=\"v4.8.5:e504f2e1\">\n          The DCS will no longer return jetty version strings in error pages\n          or HTTP headers.\n        </p>\n      </dd>\n\n      <dt>New <code>--service-only</code> option for the DCS</dt>\n      <dd>\n        <p id=\"v4.8.5:85ceb2ce\">\n          The DCS launcher accepts a new <code>--service-only</code> option that\n          starts the server with only the <code>/service</code> context, omitting\n          the demo web application and other bundled contexts.\n        </p>\n      </dd>\n    </dl>\n  </section>\n\n  <section id=\"v4.8.4\">\n    <h2>\n        <a class=\"anchor\" href=\"#v4.8.4\" aria-hidden=\"true\"><svg aria-hidden=\"true\" height=\"16\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Version 4.8.4\n      </h2>\n\n    <time datetime=\"2026-01-12\"></time>\n\n    <p id=\"v4.8.4:272b704e\">\n      The 4.8.4 release includes an update of dependencies, build\n      plugins and gradle build system.\n    </p>\n  </section>\n\n  <section id=\"v4.8.3\">\n    <h2>\n        <a class=\"anchor\" href=\"#v4.8.3\" aria-hidden=\"true\"><svg aria-hidden=\"true\" height=\"16\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Version 4.8.3\n      </h2>\n\n    <time datetime=\"2025-10-10\"></time>\n\n    <p id=\"v4.8.3:b53297b4\">\n      The 4.8.3 release fixes the user interface to correctly pass the user-provided\n      partner ID to the eTools search service.\n    </p>\n\n    <p id=\"v4.8.3:1556a150\">\n      This is an internal, non-maven release.\n    </p>\n  </section>\n\n  <section id=\"v4.8.2\">\n    <h2>\n        <a class=\"anchor\" href=\"#v4.8.2\" aria-hidden=\"true\"><svg aria-hidden=\"true\" height=\"16\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Version 4.8.2\n      </h2>\n\n    <time datetime=\"2025-09-24\"></time>\n\n    <p id=\"v4.8.2:03f8059c\">\n      The 4.8.2 release fixes the user interface to correctly pass the user-provided\n      customer ID to the eTools search service.\n    </p>\n\n    <p id=\"v4.8.2:1556a150\">\n      This is an internal, non-maven release.\n    </p>\n  </section>\n\n  <section id=\"v4.8.0\">\n    <h2>\n        <a class=\"anchor\" href=\"#v4.8.0\" aria-hidden=\"true\"><svg aria-hidden=\"true\" height=\"16\" viewBox=\"0 0 16 16\" width=\"16\"><path fill-rule=\"evenodd\" d=\"M4 9h1v1H4c-1.5 0-3-1.69-3-3.5S2.55 3 4 3h4c1.45 0 3 1.69 3 3.5 0 1.41-.91 2.72-2 3.25V8.59c.58-.45 1-1.27 1-2.09C10 5.22 8.98 4 8 4H4c-.98 0-2 1.22-2 2.5S3 9 4 9zm9-3h-1v1h1c1 0 2 1.22 2 2.5S13.98 12 13 12H9c-.98 0-2-1.22-2-2.5 0-.83.42-1.64 1-2.09V6.25c-1.09.53-2 1.84-2 3.25C6 11.31 7.55 13 9 13h4c1.45 0 3-1.69 3-3.5S14.5 6 13 6z\"></path></svg></a>Version 4.8.0\n      </h2>\n\n    <time datetime=\"2025-05-21\"></time>\n\n    <p id=\"v4.8.0:8e68de59\">\n      This release includes an upgrade of dependencies,\n      build plugins and a switch to Java 21 as the minimum\n      runtime platform (a consequence of switching to\n      Lucene 10).\n    </p>\n\n    <dl>\n      <dt>Dependency upgrades</dt>\n      <dd>\n        <p id=\"v4.8.0:8494e93c\">\n          jackson to 2.19.0,\n          jetty to 11.0.25,\n          Lucene to 10.2.1,\n          slf4j to 2.0.17,\n          log4j to 2.24.3\n          (and other transitive updates).\n        </p>\n      </dd>\n    </dl>\n  </section>\n\n</article>","tableOfContents":[{"heading":"Version 4.8.5","anchor":"v4.8.5"},{"heading":"Version 4.8.4","anchor":"v4.8.4"},{"heading":"Version 4.8.3","anchor":"v4.8.3"},{"heading":"Version 4.8.2","anchor":"v4.8.2"},{"heading":"Version 4.8.0","anchor":"v4.8.0"}]}},"pageContext":{"slug":"/v4.8.x/"}},"staticQueryHashes":["2081922839"]}